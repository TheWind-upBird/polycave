{
  "name": "polycave",
  "description": "Polycave 多言 — polyglot compression across 8 dialects/classical languages × 3 intensity levels (cantonese, henanese, shanghainese, beijing, wenyan, kobun, old-english, latin). Cuts LLM output 60-85% while keeping code untouched.",
  "version": "0.2.0",
  "author": {
    "name": "TheWind-upBird",
    "url": "https://github.com/TheWind-upBird"
  },
  "homepage": "https://github.com/TheWind-upBird/polycave",
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/polycave-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading polycave mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/polycave-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking polycave mode..."
          }
        ]
      }
    ]
  }
}
